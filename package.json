{
  "name": "traces-dev",
  "version": "0.1.0",
  "description": "Local-first LLM observability. PostgreSQL only. Deploy in 30 seconds.",
  "license": "MIT",
  "author": "parallelromb",
  "repository": {
    "type": "git",
    "url": "https://github.com/parallelromb/traces.git"
  },
  "bin": {
    "traces": "./dist/bin/traces.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
